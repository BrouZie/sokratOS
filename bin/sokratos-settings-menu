#!/usr/bin/env bash

HYPR_PATH="$HOME/.config/hypr/hyprland.conf"

OPTIONS=(
	"¾░Åİ   Themes"
	"¯¼ú   Styles"
	"¾░©ë   Wallpapers"
	"´üä   Edit Hyprland"
	"¾░ï▒   Focus Mode"
	"¾░ûö   Night Mode"
	"¾░ü¿   Auto-Colorizer-Mode"
)

SELECTED=$(printf '%s\n' "${OPTIONS[@]}" | \
  rofi -dmenu -i -p "Settings" \
	-no-show-icons)

case "$SELECTED" in
	*"Themes") sokratos-theme-menu ;;
	*"Wallpapers") sokratos-wallpaper-menu ;;
	*"Styles") sokratos-style-menu ;;
	*"Focus Mode") sokratos-focus-mode ;;
	*"Night Mode") sokratos-night-mode ;;
	*"Edit Hyprland") xdg-terminal-exec "$EDITOR" "$HYPR_PATH" ;;
	*"Auto-Colorizer-Mode") sokratos-switch-color-backend ;;
	*) exit 0;;
esac

#!/usr/bin/env bash

OPTIONS=(
	"ó°€»    Applications"
	"ď€“    Settings"
	"ó°‚š    Notifications"
	"ď„¨    Keybindings"
	"ď‹¶    Exit System"
	"ó°š°    Update System"
)

SELECTED=$(printf '%s\n' "${OPTIONS[@]}" | \
	rofi -dmenu -i -p "sokratOS" \
	-no-show-icons)

case "$SELECTED" in
	*"Applications") rofi -show drun -replace -i ;;
	*"Settings") sokratos-settings-menu ;;
	*"Notifications") swaync-client -t -sw ;;
	*"Keybindings") sokratos-keybind-menu ;;
	*"Exit System") sokratos-power-menu ;;
	*"Update System") sokratos-floaterminal sokratos-update ;;
	*) exit ;;
esac

#!/usr/bin/env bash

# Check colorbackend!
STATE_FILE="$HOME/.config/sokratOS/.color-backend"

# Read current state (default to matugen)
if [[ -f "$STATE_FILE" ]]; then
	CURRENT=$(<"$STATE_FILE")
else
	CURRENT="matugen"
fi

# EXITING EARLY ON MATUGEN BACKEND!
if [[ "$CURRENT" == "matugen" ]]; then
	notify-send \
		--urgency=critical \
		--expire-time=10000 \
		"NB!" "✦ Auto-Colorizer-Mode must be disabled!"
	exit 0;
fi

THEMES_DIR="$HOME/.local/share/sokratOS/themes"
CURRENT_LINK="$HOME/.config/sokratOS/current/theme"

notify-send "Choose the desired colorscheme!"

mkdir -p "$HOME/.config/sokratOS/current"
cd "$THEMES_DIR" || exit 1

SELECTED_THEME=$(
  for theme in */; do
    theme="${theme%/}"
    echo -en "$theme\0icon\x1f$theme\n"
  done | rofi -dmenu -p "Themes" -no-show-icons
)

if [[ -n "${SELECTED_THEME:-}" ]]; then
  TARGET="$THEMES_DIR/$SELECTED_THEME"
  [[ -d "$TARGET" ]] || exit 1

  # Create new symlink and move into place (prevents partial state)
  TMP_LINK="${CURRENT_LINK}.new"
  ln -sfn "$TARGET" "$TMP_LINK"
  mv -Tf "$TMP_LINK" "$CURRENT_LINK"

	# Restart applications
	sokratos-export-wal
	refresh-app-daemons
	pywalfox update
	pkill -SIGUSR1 kitty
	tmux source-file ~/.tmux.conf
	hyprctl reload

  notify-send "Theme $SELECTED_THEME selected!"
fi
